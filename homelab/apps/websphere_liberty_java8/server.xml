<server>
    <featureManager>
        <feature>javaee-7.0</feature>
        <feature>adminCenter-1.0</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="9080"
                  httpsPort="9443"/>

    <keyStore id="defaultKeyStore" password="changeit"/>
    <ltpa keysPassword="changeit"/>

    <basicRegistry id="basic" realm="BasicRealm">
        <user name="admin" password="adminpwd"/>
    </basicRegistry>

    <administrator-role>
        <user>admin</user>
    </administrator-role>

    <httpAccessLogging logFormat='%h %u %t "%r" %s %b'/>

    <!--
        In case of problems activate logging ALL
        <logging traceSpecification="*=all"/>
    -->
    <logging traceSpecification="*=info"/>

    <remoteFileAccess>
        <writeDir>${server.config.dir}</writeDir>
    </remoteFileAccess>
</server>